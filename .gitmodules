; .gitmodules — explicitly declare godot-cpp to avoid cleanup failures
; The CI downloads `godot-cpp` as a tarball and does not use git submodules,
; but GitHub runner cleanup iterates entries in .gitmodules. Ensure the
; submodule has a valid URL so `git submodule foreach` does not fail.

[submodule "polylang plugin/godot-cpp"]
	path = polylang plugin/godot-cpp
	url = https://github.com/godotengine/godot-cpp.git
